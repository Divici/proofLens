{
  "name": "prooflens",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:prod-sim": "cross-env PROOFLENS_PROD_SIM=1 playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "eval:generate": "node eval/generate-golden.mjs",
    "eval:deterministic": "tsx eval/runner.ts --layer=1",
    "eval": "tsx eval/runner.ts --layer=2",
    "eval:dry": "tsx eval/runner.ts --dry-run"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@hookform/resolvers": "^3.10.0",
    "@react-pdf/renderer": "^4.1.6",
    "bottleneck": "^2.19.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convert-units": "^2.3.4",
    "fastest-levenshtein": "^1.0.16",
    "fuzzball": "^2.2.2",
    "idb": "^8.0.3",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "openai": "^4.86.1",
    "papaparse": "^5.5.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.55.0",
    "remove-markdown": "^0.6.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.6.0",
    "sharp": "^0.34.0",
    "sonner": "^2.0.0",
    "tailwind-merge": "^3.5.0",
    "tesseract.js": "^5.1.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.2.0",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "fake-indexeddb": "^6.0.1",
    "fast-check": "^3.23.2",
    "jsdom": "^26.0.0",
    "msw": "^2.7.3",
    "playwright": "^1.51.0",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^3.0.7"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
